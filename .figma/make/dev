#!/bin/bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT_DIR"

ENV_FILE=".figma/make/env"
if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
fi

COMPOSE=(docker compose -f compose.figma.yaml)
PORT="${PORT:-5173}"
FIGMA_MAKE_URL="${FIGMA_MAKE_URL:-http://localhost:$PORT}"
FIGMA_INTERNAL_APP_URL="${FIGMA_INTERNAL_APP_URL:-http://localhost:8000}"

echo "Starting Figma Make services..."
"${COMPOSE[@]}" up -d --wait

echo "Starting Administration watcher for $FIGMA_MAKE_URL..."
"${COMPOSE[@]}" exec -T web env APP_URL="$FIGMA_INTERNAL_APP_URL" PORT="$PORT" composer watch:admin
